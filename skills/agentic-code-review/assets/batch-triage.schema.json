{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agentic Code Review Batch Triage",
  "type": "object",
  "additionalProperties": false,
  "required": ["items", "human_attention_plan"],
  "properties": {
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "category", "reason", "required_next_evidence"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "category": {
            "type": "string",
            "enum": ["Safe-looking", "Needs work", "High-risk", "Not reviewable"]
          },
          "risk_tier": {
            "type": "string",
            "enum": ["L0", "L1", "L2", "L3", "L4", "Unknown"]
          },
          "reason": { "type": "string", "minLength": 1 },
          "required_next_evidence": { "type": "string" },
          "human_owner": { "type": "string" }
        }
      }
    },
    "human_attention_plan": {
      "type": "string",
      "minLength": 1
    }
  }
}
